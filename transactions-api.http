@baseUrl = http://127.0.0.1:8000
@token = PASTE_BEARER_TOKEN_HERE
@accountId = 3
@incomeCategoryId = 3
@expenseCategoryId = 4
@systemCategoryId = 5
@transactionId = 8

### Login
POST {{baseUrl}}/api/login
Accept: application/json
Content-Type: application/json

{
  "email": "test@example.com",
  "password": "password"
}

### Show current user
GET {{baseUrl}}/api/user
Accept: application/json
Authorization: Bearer {{token}}

### Logout
POST {{baseUrl}}/api/logout
Accept: application/json
Authorization: Bearer {{token}}

{}

### Create account
POST {{baseUrl}}/api/accounts
Accept: application/json
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "BCA",
  "type": "bank",
  "balance": 0
}

### List accounts
GET {{baseUrl}}/api/accounts
Accept: application/json
Authorization: Bearer {{token}}

### Reconcile account with matching balance
POST {{baseUrl}}/api/accounts/{{accountId}}/reconcile
Accept: application/json
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "actual_balance": 150000
}

### Reconcile account with higher actual balance
POST {{baseUrl}}/api/accounts/{{accountId}}/reconcile
Accept: application/json
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "actual_balance": 175000
}

### Reconcile account with lower actual balance
POST {{baseUrl}}/api/accounts/{{accountId}}/reconcile
Accept: application/json
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "actual_balance": 125000
}

### Create expense category
POST {{baseUrl}}/api/categories
Accept: application/json
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Jajan Kampus",
  "type": "expense",
  "icon": "coffee",
  "color": "#F59E0B"
}

### List all active categories available to the user
GET {{baseUrl}}/api/categories
Accept: application/json
Authorization: Bearer {{token}}

### List income categories
GET {{baseUrl}}/api/categories?type=income
Accept: application/json
Authorization: Bearer {{token}}

### List expense categories
GET {{baseUrl}}/api/categories?type=expense
Accept: application/json
Authorization: Bearer {{token}}

### Create category with invalid color
POST {{baseUrl}}/api/categories
Accept: application/json
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Warna Salah",
  "type": "expense",
  "icon": "coffee",
  "color": "1234567"
}

### Try updating a system category
PATCH {{baseUrl}}/api/categories/{{systemCategoryId}}
Accept: application/json
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Coba Edit Sistem"
}

### Try deleting a system category
DELETE {{baseUrl}}/api/categories/{{systemCategoryId}}
Accept: application/json
Authorization: Bearer {{token}}

### Show current settings
GET {{baseUrl}}/api/settings
Accept: application/json
Authorization: Bearer {{token}}

### Update settings
PATCH {{baseUrl}}/api/settings
Accept: application/json
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "locale": "en",
  "currency": "USD"
}

### Update settings with unsupported values
PATCH {{baseUrl}}/api/settings
Accept: application/json
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "locale": "jp",
  "currency": "JPY"
}

### Update settings with empty payload
PATCH {{baseUrl}}/api/settings
Accept: application/json
Content-Type: application/json
Authorization: Bearer {{token}}

{}

### List notifications
GET {{baseUrl}}/api/notifications
Accept: application/json
Authorization: Bearer {{token}}

### Mark all notifications as read
PATCH {{baseUrl}}/api/notifications/read-all
Accept: application/json
Authorization: Bearer {{token}}

### Mark a single notification as read
PATCH {{baseUrl}}/api/notifications/1/read
Accept: application/json
Authorization: Bearer {{token}}

### List all transactions
GET {{baseUrl}}/api/transactions
Accept: application/json
Authorization: Bearer {{token}}

### Filter transactions by type
GET {{baseUrl}}/api/transactions?type=expense
Accept: application/json
Authorization: Bearer {{token}}

### Filter transactions by date range
GET {{baseUrl}}/api/transactions?date_from=2026-05-01&date_to=2026-05-31
Accept: application/json
Authorization: Bearer {{token}}

### Filter transactions by account
GET {{baseUrl}}/api/transactions?account_id={{accountId}}
Accept: application/json
Authorization: Bearer {{token}}

### Show single transaction
GET {{baseUrl}}/api/transactions/{{transactionId}}
Accept: application/json
Authorization: Bearer {{token}}

### Create income transaction
POST {{baseUrl}}/api/transactions
Accept: application/json
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "account_id": {{accountId}},
  "category_id": {{incomeCategoryId}},
  "type": "income",
  "amount": 5000000,
  "description": "Gaji bulanan",
  "transaction_date": "2026-05-07",
  "notes": "Transfer perusahaan",
  "tags": ["gaji", "bulanan"]
}

### Create expense transaction
POST {{baseUrl}}/api/transactions
Accept: application/json
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "account_id": {{accountId}},
  "category_id": {{expenseCategoryId}},
  "type": "expense",
  "amount": 15000,
  "description": "Makan siang",
  "transaction_date": "2026-05-07",
  "reference_number": "TRX-001",
  "notes": "Beli di kantin",
  "tags": ["makan", "kantin"]
}

### Create expense transaction with system category
POST {{baseUrl}}/api/transactions
Accept: application/json
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "account_id": {{accountId}},
  "category_id": {{systemCategoryId}},
  "type": "expense",
  "amount": 25000,
  "description": "Naik ojek",
  "transaction_date": "2026-05-07",
  "tags": ["transport"]
}

### Update transaction
PATCH {{baseUrl}}/api/transactions/{{transactionId}}
Accept: application/json
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "notes": "Update catatan transaksi",
  "tags": ["makan", "siang", "kampus"]
}

### Invalid tags format
POST {{baseUrl}}/api/transactions
Accept: application/json
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "account_id": {{accountId}},
  "category_id": {{expenseCategoryId}},
  "type": "expense",
  "amount": 12000,
  "transaction_date": "2026-05-07",
  "tags": "makan"
}

### Mismatched transaction type and category type
PATCH {{baseUrl}}/api/transactions/{{transactionId}}
Accept: application/json
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "type": "income",
  "category_id": {{expenseCategoryId}}
}

### Delete transaction
DELETE {{baseUrl}}/api/transactions/{{transactionId}}
Accept: application/json
Authorization: Bearer {{token}}

### Edge case: no token
GET {{baseUrl}}/api/transactions
Accept: application/json

### Edge case: invalid amount
POST {{baseUrl}}/api/transactions
Accept: application/json
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "account_id": {{accountId}},
  "type": "expense",
  "amount": -999,
  "transaction_date": "2026-05-07"
}

### Edge case: wrong type
POST {{baseUrl}}/api/transactions
Accept: application/json
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "account_id": {{accountId}},
  "type": "belanja",
  "amount": 10000,
  "transaction_date": "2026-05-07"
}

### Export user data
GET {{baseUrl}}/api/user/export-data
Accept: application/json
Authorization: Bearer {{token}}

### Delete user account (CAUTION)
DELETE {{baseUrl}}/api/user/delete-account
Accept: application/json
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "password": "password"
}
